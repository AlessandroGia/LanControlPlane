[Unit]
Description=LAN Control Plane Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/lan-control-plane-agent/agent
EnvironmentFile=/opt/lan-control-plane-agent/agent.env
ExecStart=/opt/lan-control-plane-agent/agent/.venv/bin/python -m lan_control_plane_agent.main
Restart=always
RestartSec=5
User=root
Group=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
